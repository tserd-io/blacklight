# Blacklight private operator environment.
# Copy this file to `.env` for secrets and machine-specific overrides.
#
# Do not commit `.env`.
# Do not put real secrets in `user.env`; the local console can read/update user.env.

# ---------------------------------------------------------------------------
# Default safe mode
# ---------------------------------------------------------------------------

# Keep mock mode as the default for normal development, demos, and CI.
LLM_PROVIDER=mock
LLM_MODEL=mock-ticket-classifier

# Local SQLite trace/eval store.
TRACE_DB_PATH=traces.sqlite3

# ---------------------------------------------------------------------------
# Hosted provider: OpenAI
# ---------------------------------------------------------------------------

# To test live OpenAI calls:
# 1. install the optional dependency: pip install -e ".[openai]"
# 2. set LLM_PROVIDER=injected and LLM_PROVIDER_ADAPTER=openai
# 3. paste your key below or export it in your shell instead
# 4. use a low-cost model for smoke tests
#
# LLM_PROVIDER=injected
# LLM_PROVIDER_ADAPTER=openai
# LLM_PROVIDER_NAME=openai
# LLM_MODEL=gpt-4o-mini
# Prefer OPENAI_API_KEY for clarity. LLM_API_KEY or API_KEY can also be used
# as generic private provider-key aliases when the selected provider needs one.
OPENAI_API_KEY=
# LLM_API_KEY=
# API_KEY=

# ---------------------------------------------------------------------------
# Local/private provider: Ollama or another local model runtime
# ---------------------------------------------------------------------------

# To test a local Llama-style model through Ollama:
# 1. start Ollama
# 2. pull a model, for example: ollama pull llama3.1
# 3. set LLM_PROVIDER=injected and LLM_PROVIDER_ADAPTER=custom
# 4. use the bundled Ollama adapter below
#
# LLM_PROVIDER=injected
# LLM_PROVIDER_ADAPTER=custom
# LLM_PROVIDER_NAME=ollama
# LLM_CUSTOM_PROVIDER=blacklight.providers.ollama_provider:OllamaProvider
# LLM_MODEL=llama3.1
LLM_PROVIDER_ADAPTER=
LLM_PROVIDER_NAME=
LLM_CUSTOM_PROVIDER=
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Provider reliability controls
# ---------------------------------------------------------------------------

LLM_PROVIDER_TIMEOUT_SECONDS=30
LLM_PROVIDER_MAX_RETRIES=2

# Current MVP rate limiting is request-count based. The production direction is
# rolling token-budget quotas, tracked in docs and plans.
LLM_PROVIDER_RATE_LIMIT_REQUESTS=3
LLM_PROVIDER_RATE_LIMIT_WINDOW_SECONDS=10

# ---------------------------------------------------------------------------
# Opt-in live smoke tests
# ---------------------------------------------------------------------------

# Keep these disabled unless you intentionally want live provider checks.
# Normal tests and CI should not require OpenAI keys, Ollama, Docker, or model
# downloads.
RUN_OPENAI_PROVIDER_SMOKE=0
RUN_CUSTOM_PROVIDER_SMOKE=0
RUN_LOCAL_PROVIDER_SMOKE=0
RUN_OLLAMA_PROVIDER_SMOKE=0
