# App-managed user settings.
# Copy this to user.env for settings the local console is allowed to display and update.
# Keep .env for private operator secrets or environment-specific overrides that the app should not edit.

LLM_PROVIDER=mock
LLM_MODEL=mock-ticket-classifier
TRACE_DB_PATH=traces.sqlite3

# Optional provider settings. Keep provider secrets such as OPENAI_API_KEY in .env,
# shell environment variables, or deployment secrets, not app-editable user.env.
LLM_CUSTOM_PROVIDER=
OLLAMA_BASE_URL=http://localhost:11434

# Reliability controls.
LLM_PROVIDER_TIMEOUT_SECONDS=30
LLM_PROVIDER_MAX_RETRIES=2
LLM_PROVIDER_RATE_LIMIT_REQUESTS=3
LLM_PROVIDER_RATE_LIMIT_WINDOW_SECONDS=10
